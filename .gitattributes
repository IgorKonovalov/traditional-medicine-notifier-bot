# Normalize line endings. Without this, a Windows checkout with
# core.autocrlf=true rewrites LF→CRLF on checkout and Git warns on every
# `git status`/`git add`. Pinning eol=lf stores AND checks out LF everywhere,
# which also keeps the husky shell hooks and Docker scripts runnable.
* text=auto eol=lf

# Scripts and git hooks must stay LF or they fail under /bin/sh.
*.sh   text eol=lf
.husky/* text eol=lf

# Binary files Git must never touch (no eol conversion, no diff munging).
*.db    binary
*.sqlite binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
