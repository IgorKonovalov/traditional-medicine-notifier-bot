# Telegram Bot
BOT_TOKEN=your-telegram-bot-token

# Bot's @username (without the leading @). Used to build content cross-link
# URLs of the form https://t.me/<BOT_USERNAME>?start=<payload>.
BOT_USERNAME=YourBotName

# Database
DB_PATH=./data/tm-bot.db

# Content (markdown reference corpus)
CONTENT_DIR=./content

# Logging (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Single timezone for all scheduled notifications (MVP). Day boundaries for
# the proactive daily-push cap and the dated backup filename use this zone.
# IANA zone name (e.g. UTC, Europe/Moscow, Asia/Shanghai).
TIMEZONE=UTC

# Reminder dispatch tick (SOLICITED, user-scheduled reminders). Runs often so
# user-chosen times fire close to the minute. Not subject to the daily cap.
REMINDER_TICK_CRON=* * * * *

# Daily-tip / subscription dispatch (PROACTIVE). Evaluated in TIMEZONE. Each
# subscriber receives at most one proactive push per calendar day (the budget
# gate). Default: 09:00 daily.
DAILY_TIP_CRON=0 9 * * *

# DB backups — two variables, one per side of the docker bind mount.
# BACKUP_DIR is the path *inside* the container where the app writes.
# HOST_BACKUP_DIR is the path *on the host* bind-mounted there.
BACKUP_DIR=/var/backups/traditional-medicine-notifier-bot
HOST_BACKUP_DIR=/var/backups/traditional-medicine-notifier-bot

# Admin Telegram-id allowlist for admin-only commands. Comma-separated numeric
# ids; whitespace around commas is trimmed. Empty / unset → no admins. Find
# your numeric Telegram id by messaging @userinfobot.
# ADMIN_TELEGRAM_IDS=123456789,987654321
